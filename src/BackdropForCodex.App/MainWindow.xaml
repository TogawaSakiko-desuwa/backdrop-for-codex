<Window x:Class="BackdropForCodex.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Backdrop for Codex" Height="720" Width="980"
        MinHeight="600" MinWidth="820"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource WindowBackgroundBrush}"
        Foreground="White"
        IsVisibleChanged="Window_IsVisibleChanged">
  <Grid Margin="28">
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="3*" />
      <ColumnDefinition Width="24" />
      <ColumnDefinition Width="2*" />
    </Grid.ColumnDefinitions>

    <Border Grid.Column="0" Background="#111318" CornerRadius="14" ClipToBounds="True">
      <Grid>
        <Image x:Name="ImagePreview" Stretch="UniformToFill" Visibility="Collapsed" />
        <MediaElement x:Name="VideoPreview" Stretch="UniformToFill" LoadedBehavior="Manual"
                      UnloadedBehavior="Stop" IsMuted="True" Visibility="Collapsed"
                      MediaEnded="VideoPreview_MediaEnded" MediaFailed="VideoPreview_MediaFailed" />
        <TextBlock x:Name="EmptyPreview" Text="选择一张图片或一段静音视频进行预览"
                   HorizontalAlignment="Center" VerticalAlignment="Center"
                   Foreground="#9BA3AF" FontSize="18" TextWrapping="Wrap" />
      </Grid>
    </Border>

    <ScrollViewer Grid.Column="2" VerticalScrollBarVisibility="Auto">
      <StackPanel>
        <TextBlock Text="Backdrop for Codex" FontSize="30" FontWeight="SemiBold" />
        <TextBlock Margin="0,8,0,24" Foreground="#AAB2BF" TextWrapping="Wrap"
                   Text="为官方 Codex 添加可随时关闭的本地动态背景。非 OpenAI 官方项目。" />

        <Button x:Name="ChooseMediaButton" Height="42" Content="选择壁纸…" Click="ChooseMedia_Click" />
        <TextBlock x:Name="MediaPathText" Margin="0,8,0,18" Foreground="#AAB2BF"
                   Text="尚未选择" TextTrimming="CharacterEllipsis" ToolTipService.ShowDuration="30000" />

        <TextBlock Text="填充方式" />
        <ComboBox x:Name="FitComboBox" SelectedIndex="0" Margin="0,4,0,14" Height="34">
          <ComboBoxItem Content="裁切铺满（Cover）" />
          <ComboBoxItem Content="完整显示（Contain）" />
        </ComboBox>

        <TextBlock Text="面板不透明度" />
        <Slider x:Name="PanelOpacitySlider" Minimum="0.60" Maximum="0.95" Value="0.78"
                TickFrequency="0.01" Margin="0,4,0,14" />
        <TextBlock Text="模糊强度" />
        <Slider x:Name="BlurSlider" Minimum="0" Maximum="24" Value="14"
                TickFrequency="1" Margin="0,4,0,20" />

        <CheckBox x:Name="RiskAcknowledgement" Margin="0,0,0,18"
                  Unchecked="RiskAcknowledgement_Unchecked">
          <TextBlock TextWrapping="Wrap"
                     Text="我了解：增强启动会开启仅限本机的 Chromium 调试端口；该端口会持续到 Codex 退出。" />
        </CheckBox>

        <Button x:Name="LaunchButton" Height="46" FontWeight="SemiBold"
                Background="{StaticResource AccentBrush}" Foreground="#101318"
                Content="保存并增强启动 Codex" Click="Launch_Click" />
        <Grid Margin="0,10,0,0">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="10" />
            <ColumnDefinition Width="*" />
          </Grid.ColumnDefinitions>
          <Button x:Name="PauseButton" Grid.Column="0" Height="40" Content="暂停视频"
                  Click="Pause_Click" IsEnabled="False" />
          <Button Grid.Column="2" Height="40" Content="关闭壁纸并恢复官方背景"
                  Click="Disable_Click" />
        </Grid>

        <TextBlock x:Name="StatusText" Margin="0,20,0,0" Foreground="#9BA3AF"
                   TextWrapping="Wrap" Text="状态：尚未启动" />
      </StackPanel>
    </ScrollViewer>
  </Grid>
</Window>
