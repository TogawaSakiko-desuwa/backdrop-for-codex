<ui:FluentWindow x:Class="BackdropForCodex.App.MainWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:converters="clr-namespace:BackdropForCodex.App.Converters"
                 xmlns:localization="clr-namespace:BackdropForCodex.App.Services.Localization"
                 xmlns:settings="clr-namespace:BackdropForCodex.Core.Settings;assembly=BackdropForCodex.Core"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 Title="{localization:Loc App_Title, Fallback='Backdrop for Codex'}"
                 Width="1040"
                 Height="700"
                 MinWidth="640"
                 MinHeight="520"
                 WindowStartupLocation="CenterScreen"
                 WindowBackdropType="Mica"
                 WindowCornerPreference="Round"
                 ExtendsContentIntoTitleBar="True"
                 AllowDrop="True"
                 Closing="Window_Closing"
                 DragEnter="Window_DragEnter"
                 DragOver="Window_DragOver"
                 DragLeave="Window_DragLeave"
                 Drop="Window_Drop"
                 IsVisibleChanged="Window_IsVisibleChanged"
                 SizeChanged="Window_SizeChanged">
  <ui:FluentWindow.Resources>
    <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    <converters:MediaThumbnailConverter x:Key="MediaThumbnailConverter" />
    <converters:UiStatusToneToInfoBarSeverityConverter x:Key="StatusToneConverter" />
  </ui:FluentWindow.Resources>

  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="48" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <ui:TitleBar Grid.Row="0"
                 Title="{localization:Loc App_Title, Fallback='Backdrop for Codex'}">
      <ui:TitleBar.Icon>
        <ui:ImageIcon Source="{StaticResource AppIconImage}" />
      </ui:TitleBar.Icon>
      <ui:TitleBar.TrailingContent>
        <ui:Button Margin="0,0,138,0"
                   Width="38"
                   Height="34"
                   Appearance="Transparent"
                   ToolTip="{localization:Loc Action_Settings, Fallback=Settings}"
                   AutomationProperties.Name="{localization:Loc Action_Settings, Fallback=Settings}"
                   IsEnabled="{Binding CanEdit}"
                   Click="Settings_Click">
          <ui:SymbolIcon Symbol="Settings24" />
        </ui:Button>
      </ui:TitleBar.TrailingContent>
    </ui:TitleBar>

    <Grid x:Name="MainContentGrid" Grid.Row="1" Margin="24,14,24,14">
      <Grid.RowDefinitions>
        <RowDefinition x:Name="MainTopRow" Height="*" />
        <RowDefinition x:Name="MainGapRow" Height="0" />
        <RowDefinition x:Name="MainBottomRow" Height="0" />
      </Grid.RowDefinitions>
      <Grid.ColumnDefinitions>
        <ColumnDefinition x:Name="PreviewColumn" Width="3*" />
        <ColumnDefinition x:Name="ColumnGap" Width="20" />
        <ColumnDefinition x:Name="InspectorColumn" Width="2*" MinWidth="330" />
      </Grid.ColumnDefinitions>

      <Grid x:Name="PreviewPane" Grid.Row="0" Grid.Column="0">
        <Grid.RowDefinitions>
          <RowDefinition Height="*" />
          <RowDefinition Height="14" />
          <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ui:Card Grid.Row="0" ClipToBounds="True">
          <Grid x:Name="PreviewSurface"
                MinHeight="220"
                Background="#171A20"
                ClipToBounds="True">
            <Grid x:Name="MediaViewport"
                  ClipToBounds="True"
                  SizeChanged="MediaViewport_SizeChanged">
              <Canvas x:Name="MediaCanvas"
                      ClipToBounds="True"
                      IsHitTestVisible="False">
                <Image x:Name="ImagePreview"
                       Stretch="Fill"
                       Visibility="Collapsed">
                  <Image.Effect>
                    <BlurEffect Radius="{Binding BlurPx}"
                                RenderingBias="Performance" />
                  </Image.Effect>
                </Image>
                <MediaElement x:Name="VideoPreview"
                              Stretch="Fill"
                              LoadedBehavior="Manual"
                              UnloadedBehavior="Stop"
                              IsMuted="True"
                              ScrubbingEnabled="True"
                              Visibility="Collapsed"
                              MediaOpened="VideoPreview_MediaOpened"
                              MediaEnded="VideoPreview_MediaEnded"
                              MediaFailed="VideoPreview_MediaFailed">
                  <MediaElement.Effect>
                    <BlurEffect Radius="{Binding BlurPx}"
                                RenderingBias="Performance" />
                  </MediaElement.Effect>
                </MediaElement>
              </Canvas>
            </Grid>

            <!-- Theme-aware readability veil: media, veil, then the simulated Codex UI. -->
            <Border x:Name="PreviewThemeOverlay"
                    Background="Black"
                    Visibility="Collapsed"
                    IsHitTestVisible="False" />

            <Border x:Name="EmptyPreview"
                    Margin="32"
                    Background="Transparent">
              <StackPanel HorizontalAlignment="Center"
                          VerticalAlignment="Center"
                          MaxWidth="340">
                <Border Width="64"
                        Height="64"
                        Margin="0,0,0,16"
                        CornerRadius="18"
                        Background="#242B36">
                  <ui:SymbolIcon Symbol="Image24"
                                 FontSize="30"
                                 Foreground="#A9C7FF"
                                 HorizontalAlignment="Center"
                                 VerticalAlignment="Center" />
                </Border>
                <TextBlock Text="{localization:Loc Hint_NoMedia, Fallback='Choose media to start designing your wallpaper.'}"
                           Foreground="#F5F7FA"
                           FontSize="18"
                           FontWeight="SemiBold"
                           TextAlignment="Center"
                           TextWrapping="Wrap" />
                <TextBlock Margin="0,8,0,0"
                           Text="{localization:Loc Hint_DropMedia, Fallback='Drop one image or video here'}"
                           Foreground="#AAB2BF"
                           TextAlignment="Center" />
              </StackPanel>
            </Border>

            <!-- Keep the preview compact, but preserve Codex's left navigation,
                 central task surface, and right context panel. -->
            <Grid Margin="12">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.2*" MinWidth="88" />
                <ColumnDefinition Width="8" />
                <ColumnDefinition Width="3.5*" MinWidth="150" />
                <ColumnDefinition Width="8" />
                <ColumnDefinition Width="1.35*" MinWidth="96" />
              </Grid.ColumnDefinitions>

              <Grid Grid.Column="0">
                <Border CornerRadius="12"
                        Background="{DynamicResource ApplicationBackgroundBrush}"
                        Opacity="{Binding PanelOpacity}" />
                <Grid Margin="12">
                  <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="12" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                  </Grid.RowDefinitions>
                  <StackPanel Orientation="Horizontal">
                    <Border Width="18" Height="18" CornerRadius="5"
                            Background="{DynamicResource AccentFillColorDefaultBrush}">
                      <TextBlock Text="C"
                                 HorizontalAlignment="Center"
                                 VerticalAlignment="Center"
                                 Foreground="White"
                                 FontSize="10"
                                 FontWeight="Bold" />
                    </Border>
                    <TextBlock Margin="7,0,0,0"
                               VerticalAlignment="Center"
                               Text="Codex"
                               FontWeight="SemiBold" />
                  </StackPanel>
                  <StackPanel Grid.Row="2">
                    <Border Height="26" CornerRadius="7"
                            Background="{DynamicResource ControlFillColorDefaultBrush}">
                      <StackPanel Margin="8,0" Orientation="Horizontal"
                                  VerticalAlignment="Center">
                        <ui:SymbolIcon Symbol="Add16" FontSize="11" />
                        <Rectangle Width="44" Height="5" Margin="6,0,0,0"
                                   RadiusX="2.5" RadiusY="2.5"
                                   Fill="{DynamicResource TextFillColorSecondaryBrush}" />
                      </StackPanel>
                    </Border>
                    <Rectangle Height="5" Margin="8,12,18,0"
                               RadiusX="2.5" RadiusY="2.5"
                               Fill="{DynamicResource TextFillColorSecondaryBrush}"
                               Opacity="0.72" />
                    <Rectangle Height="5" Margin="8,10,10,0"
                               RadiusX="2.5" RadiusY="2.5"
                               Fill="{DynamicResource TextFillColorSecondaryBrush}"
                               Opacity="0.58" />
                    <Rectangle Height="5" Margin="8,10,24,0"
                               RadiusX="2.5" RadiusY="2.5"
                               Fill="{DynamicResource TextFillColorSecondaryBrush}"
                               Opacity="0.45" />
                  </StackPanel>
                  <Ellipse Grid.Row="3" Width="18" Height="18"
                           HorizontalAlignment="Left"
                           Fill="{DynamicResource AccentFillColorSecondaryBrush}" />
                </Grid>
              </Grid>

              <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                  <RowDefinition Height="34" />
                  <RowDefinition Height="*" />
                  <RowDefinition Height="36" />
                </Grid.RowDefinitions>
                <Border Grid.Row="0"
                        CornerRadius="10"
                        Background="{DynamicResource ApplicationBackgroundBrush}"
                        Opacity="{Binding PanelOpacity}" />
                <Grid Grid.Row="0" Margin="11,0">
                  <Rectangle Width="82" Height="6"
                             HorizontalAlignment="Left"
                             VerticalAlignment="Center"
                             RadiusX="3" RadiusY="3"
                             Fill="{DynamicResource TextFillColorPrimaryBrush}"
                             Opacity="0.8" />
                  <StackPanel HorizontalAlignment="Right"
                              VerticalAlignment="Center"
                              Orientation="Horizontal">
                    <Ellipse Width="6" Height="6"
                             Fill="{DynamicResource AccentFillColorDefaultBrush}" />
                    <Rectangle Width="28" Height="5" Margin="6,0,0,0"
                               RadiusX="2.5" RadiusY="2.5"
                               Fill="{DynamicResource TextFillColorSecondaryBrush}" />
                  </StackPanel>
                </Grid>

                <StackPanel Grid.Row="1"
                            Margin="14,12"
                            VerticalAlignment="Center">
                  <Border Width="72"
                          Height="24"
                          HorizontalAlignment="Right"
                          CornerRadius="8"
                          Background="{DynamicResource ControlFillColorDefaultBrush}" />
                  <Border Height="42"
                          Margin="0,9,26,0"
                          CornerRadius="9"
                          Background="{DynamicResource ApplicationBackgroundBrush}"
                          Opacity="{Binding PanelOpacity}" />
                  <Border Width="96"
                          Height="24"
                          Margin="0,9,0,0"
                          HorizontalAlignment="Left"
                          CornerRadius="8"
                          Background="{DynamicResource ControlFillColorDefaultBrush}" />
                </StackPanel>

                <Border Grid.Row="2"
                        CornerRadius="10"
                        Background="{DynamicResource ApplicationBackgroundBrush}"
                        Opacity="{Binding PanelOpacity}" />
                <Grid Grid.Row="2" Margin="11,0">
                  <Rectangle Height="5"
                             Margin="0,0,42,0"
                             VerticalAlignment="Center"
                             RadiusX="2.5" RadiusY="2.5"
                             Fill="{DynamicResource TextFillColorSecondaryBrush}"
                             Opacity="0.55" />
                  <Border Width="22" Height="22"
                          HorizontalAlignment="Right"
                          CornerRadius="7"
                          Background="{DynamicResource AccentFillColorDefaultBrush}">
                    <ui:SymbolIcon Symbol="Send24"
                                   FontSize="11"
                                   Foreground="White" />
                  </Border>
                </Grid>
              </Grid>

              <Grid Grid.Column="4">
                <Border CornerRadius="12"
                        Background="{DynamicResource ApplicationBackgroundBrush}"
                        Opacity="{Binding PanelOpacity}" />
                <StackPanel Margin="12">
                  <TextBlock Text="{localization:Loc Section_Preview, Fallback=Preview}"
                             FontWeight="SemiBold" />
                  <Rectangle Height="5" Margin="0,12,10,0"
                             RadiusX="2.5" RadiusY="2.5"
                             Fill="{DynamicResource TextFillColorSecondaryBrush}"
                             Opacity="0.72" />
                  <Rectangle Height="5" Margin="0,10,22,0"
                             RadiusX="2.5" RadiusY="2.5"
                             Fill="{DynamicResource TextFillColorSecondaryBrush}"
                             Opacity="0.55" />
                  <Border Height="38" Margin="0,14,0,0"
                          CornerRadius="8"
                          Background="{DynamicResource ControlFillColorDefaultBrush}" />
                  <Border Height="24" Margin="0,8,0,0"
                          CornerRadius="8"
                          Background="{DynamicResource ControlFillColorDefaultBrush}" />
                </StackPanel>
              </Grid>
            </Grid>

            <Border x:Name="FocusInteractionSurface"
                    Background="#01FFFFFF"
                    IsEnabled="{Binding CanAdjustFocus}"
                    IsHitTestVisible="{Binding CanAdjustFocus}"
                    Focusable="{Binding CanAdjustFocus}"
                    ClipToBounds="True"
                    Cursor="SizeAll"
                    ToolTip="{localization:Loc Focus_AutomationHelp, Fallback='Drag to set the crop focus. Arrow keys move one percent; hold Shift to move ten percent.'}"
                    AutomationProperties.Name="{localization:Loc Focus_AutomationName, Fallback='Wallpaper crop focus'}"
                    AutomationProperties.HelpText="{localization:Loc Focus_AutomationHelp, Fallback='Drag to set the crop focus. Arrow keys move one percent; hold Shift to move ten percent.'}"
                    AutomationProperties.ItemStatus="{Binding FocusLabel}"
                    MouseLeftButtonDown="FocusInteractionSurface_MouseLeftButtonDown"
                    MouseMove="FocusInteractionSurface_MouseMove"
                    MouseLeftButtonUp="FocusInteractionSurface_MouseLeftButtonUp"
                    LostMouseCapture="FocusInteractionSurface_LostMouseCapture"
                    KeyDown="FocusInteractionSurface_KeyDown">
              <Canvas IsHitTestVisible="False">
                <Grid x:Name="FocusIndicator"
                      Width="34"
                      Height="34"
                      Opacity="0">
                  <Ellipse Fill="#66000000"
                           Stroke="White"
                           StrokeThickness="2" />
                  <Line X1="17" Y1="5" X2="17" Y2="29"
                        Stroke="White"
                        StrokeThickness="1" />
                  <Line X1="5" Y1="17" X2="29" Y2="17"
                        Stroke="White"
                        StrokeThickness="1" />
                  <Ellipse Width="5"
                           Height="5"
                           Fill="White"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center" />
                </Grid>
              </Canvas>
            </Border>

            <Border HorizontalAlignment="Left"
                    VerticalAlignment="Bottom"
                    Margin="16"
                    Padding="10,6"
                    CornerRadius="8"
                    Background="#B020242B"
                    Visibility="{Binding HasSelectedMedia, Converter={StaticResource BooleanToVisibilityConverter}}">
              <StackPanel Orientation="Horizontal">
                <ui:SymbolIcon Symbol="Image24" Foreground="White" />
                <TextBlock Margin="7,0,0,0"
                           MaxWidth="280"
                           VerticalAlignment="Center"
                           Foreground="White"
                           FontWeight="SemiBold"
                           Text="{Binding SelectedMediaName}"
                           TextTrimming="CharacterEllipsis" />
              </StackPanel>
            </Border>

            <Border x:Name="DropOverlay"
                    Visibility="Collapsed"
                    Margin="10"
                    CornerRadius="14"
                    BorderBrush="{DynamicResource AccentFillColorDefaultBrush}"
                    BorderThickness="2"
                    Background="#D9192636"
                    IsHitTestVisible="False">
              <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <ui:SymbolIcon Symbol="ArrowUpload24"
                               FontSize="36"
                               Foreground="#DCEAFF" />
                <TextBlock Margin="0,12,0,0"
                           Text="{localization:Loc Hint_DropMedia, Fallback='Drop one image or video here'}"
                           Foreground="White"
                           FontSize="17"
                           FontWeight="SemiBold" />
              </StackPanel>
            </Border>
          </Grid>
        </ui:Card>

        <ui:Card x:Name="RecentMediaCard" Grid.Row="2">
          <Grid Margin="14,12">
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto" />
              <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Grid>
              <TextBlock Style="{StaticResource SectionHeadingStyle}"
                         Text="{localization:Loc Section_RecentMedia, Fallback='Recent media'}" />
              <ui:Button HorizontalAlignment="Right"
                         Appearance="Transparent"
                         Padding="8,3"
                         FontSize="12"
                         Content="{localization:Loc Action_ClearRecent, Fallback='Clear recent'}"
                         Command="{Binding ClearRecentsCommand}" />
            </Grid>
            <Grid Grid.Row="1" Margin="0,10,0,0">
              <TextBlock Text="{localization:Loc Hint_NoRecentMedia, Fallback='Your recently used media will appear here.'}">
                <TextBlock.Style>
                  <Style TargetType="TextBlock" BasedOn="{StaticResource CaptionTextStyle}">
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Style.Triggers>
                      <DataTrigger Binding="{Binding Recents.Count}" Value="0">
                        <Setter Property="Visibility" Value="Visible" />
                      </DataTrigger>
                    </Style.Triggers>
                  </Style>
                </TextBlock.Style>
              </TextBlock>
              <ListBox x:Name="RecentMediaList"
                       ItemsSource="{Binding Recents}"
                       IsEnabled="{Binding CanEdit}"
                       AutomationProperties.Name="{localization:Loc Section_RecentMedia, Fallback='Recent media'}"
                       Background="Transparent"
                       BorderThickness="0"
                       ScrollViewer.HorizontalScrollBarVisibility="Auto"
                       ScrollViewer.VerticalScrollBarVisibility="Disabled"
                       SelectionChanged="RecentMediaList_SelectionChanged">
                <ListBox.ItemsPanel>
                  <ItemsPanelTemplate>
                    <StackPanel Orientation="Horizontal" />
                  </ItemsPanelTemplate>
                </ListBox.ItemsPanel>
                <ListBox.ItemTemplate>
                  <DataTemplate>
                    <Grid Width="154" Margin="0,0,8,0">
                      <Border Height="58"
                              Padding="10"
                              CornerRadius="8"
                              Background="{DynamicResource ControlFillColorDefaultBrush}">
                        <Grid>
                          <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="30" />
                            <ColumnDefinition Width="*" />
                          </Grid.ColumnDefinitions>
                          <Border Width="28" Height="28" CornerRadius="7"
                                  Background="{DynamicResource AccentFillColorSecondaryBrush}"
                                  ClipToBounds="True">
                            <Grid>
                              <Image x:Name="RecentThumbnail"
                                     Source="{Binding Path, Converter={StaticResource MediaThumbnailConverter}}"
                                     Stretch="UniformToFill" />
                              <ui:SymbolIcon Symbol="Image24"
                                             HorizontalAlignment="Center"
                                             VerticalAlignment="Center">
                                <ui:SymbolIcon.Style>
                                  <Style TargetType="ui:SymbolIcon">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                      <DataTrigger Binding="{Binding ElementName=RecentThumbnail, Path=Source}"
                                                   Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Visible" />
                                      </DataTrigger>
                                    </Style.Triggers>
                                  </Style>
                                </ui:SymbolIcon.Style>
                              </ui:SymbolIcon>
                            </Grid>
                          </Border>
                          <StackPanel Grid.Column="1" Margin="8,0,0,0"
                                      VerticalAlignment="Center">
                            <TextBlock Text="{Binding DisplayName}"
                                       TextTrimming="CharacterEllipsis"
                                       FontWeight="SemiBold" />
                            <TextBlock FontSize="11"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}">
                              <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                  <Setter Property="Text" Value="{localization:Loc Media_Image, Fallback=Image}" />
                                  <Style.Triggers>
                                    <DataTrigger Binding="{Binding Kind}" Value="Video">
                                      <Setter Property="Text" Value="{localization:Loc Media_Video, Fallback=Video}" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Exists}" Value="False">
                                      <Setter Property="Text" Value="{localization:Loc Hint_MissingMedia, Fallback=Missing}" />
                                    </DataTrigger>
                                  </Style.Triggers>
                                </Style>
                              </TextBlock.Style>
                            </TextBlock>
                          </StackPanel>
                        </Grid>
                      </Border>
                      <ui:Button Width="26"
                                 Height="26"
                                 Padding="0"
                                 Margin="0,-8,-5,0"
                                 HorizontalAlignment="Right"
                                 VerticalAlignment="Top"
                                 Appearance="Secondary"
                                 ToolTip="{localization:Loc Action_Remove, Fallback=Remove}"
                                 AutomationProperties.Name="{localization:Loc Action_Remove, Fallback=Remove}"
                                 Tag="{Binding Path}"
                                 Click="RemoveRecent_Click">
                        <ui:SymbolIcon Symbol="Dismiss16" FontSize="12" />
                      </ui:Button>
                    </Grid>
                  </DataTemplate>
                </ListBox.ItemTemplate>
              </ListBox>
            </Grid>
          </Grid>
        </ui:Card>
      </Grid>

      <ScrollViewer x:Name="InspectorScroller"
                    Grid.Row="0"
                    Grid.Column="2"
                    VerticalScrollBarVisibility="Auto"
                    HorizontalScrollBarVisibility="Disabled">
        <StackPanel>
          <TextBlock Style="{StaticResource PageHeadingStyle}"
                     Text="{localization:Loc App_Title, Fallback='Backdrop for Codex'}" />
          <TextBlock Margin="0,5,0,18"
                     Style="{StaticResource CaptionTextStyle}"
                     Text="{localization:Loc App_Description, Fallback='A private, local wallpaper layer for Codex.'}" />

          <ui:Card Margin="0,0,0,12">
            <StackPanel Margin="16">
              <Grid>
                <StackPanel>
                  <TextBlock Style="{StaticResource SectionHeadingStyle}"
                             Text="{localization:Loc Section_Wallpaper, Fallback=Wallpaper}" />
                  <TextBlock Margin="0,3,105,0"
                             Style="{StaticResource CaptionTextStyle}"
                             Text="{localization:Loc Hint_SupportedFormats, Fallback='PNG, JPEG, WebP, MP4, or WebM'}" />
                </StackPanel>
                <ui:Button HorizontalAlignment="Right"
                           VerticalAlignment="Top"
                           Content="{localization:Loc Action_SelectMedia, Fallback='Choose media'}"
                           IsEnabled="{Binding CanEdit}"
                           Click="ChooseMedia_Click" />
              </Grid>
              <Border Margin="0,14,0,0"
                      Padding="11,9"
                      CornerRadius="8"
                      Background="{DynamicResource ControlFillColorDefaultBrush}">
                <Grid>
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                  </Grid.ColumnDefinitions>
                  <ui:SymbolIcon Symbol="Document24" />
                  <StackPanel Grid.Column="1" Margin="9,0,0,0">
                    <TextBlock Text="{Binding SelectedMediaName}"
                               TextTrimming="CharacterEllipsis"
                               FontWeight="SemiBold"
                               ToolTip="{Binding SelectedMediaPath}" />
                    <TextBlock Text="{localization:Loc Hint_MissingMedia, Fallback='This file is no longer available.'}"
                               Style="{StaticResource CaptionTextStyle}"
                               Visibility="{Binding IsMediaMissing, Converter={StaticResource BooleanToVisibilityConverter}}" />
                  </StackPanel>
                </Grid>
              </Border>
            </StackPanel>
          </ui:Card>

          <ui:Card Margin="0,0,0,12">
            <StackPanel Margin="16">
              <TextBlock Margin="0,0,0,14"
                         Style="{StaticResource SectionHeadingStyle}"
                         Text="{localization:Loc Section_Appearance, Fallback=Appearance}" />

              <TextBlock Style="{StaticResource InspectorLabelStyle}"
                         Text="{localization:Loc Label_Fit, Fallback='Media fit'}" />
              <ComboBox Margin="0,0,0,16"
                        SelectedValue="{Binding Fit, Mode=TwoWay}"
                        SelectedValuePath="Tag"
                        AutomationProperties.Name="{localization:Loc Label_Fit, Fallback='Media fit'}"
                        IsEnabled="{Binding CanEdit}">
                <ComboBoxItem Content="{localization:Loc Fit_Cover, Fallback='Crop to fill'}"
                              Tag="{x:Static settings:WallpaperFit.Cover}" />
                <ComboBoxItem Content="{localization:Loc Fit_Contain, Fallback='Show entire media'}"
                              Tag="{x:Static settings:WallpaperFit.Contain}" />
                <ComboBoxItem Content="{localization:Loc Fit_Stretch, Fallback='Stretch to fit'}"
                              Tag="{x:Static settings:WallpaperFit.Stretch}" />
              </ComboBox>

              <StackPanel Margin="0,0,0,16"
                          Visibility="{Binding IsCoverFit, Converter={StaticResource BooleanToVisibilityConverter}}">
                <Grid>
                  <TextBlock Style="{StaticResource InspectorLabelStyle}"
                             Text="{localization:Loc Label_Focus, Fallback='Crop focus'}" />
                  <StackPanel HorizontalAlignment="Right"
                              Orientation="Horizontal">
                    <TextBlock Margin="0,0,8,0"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                               Text="{Binding FocusLabel}" />
                    <ui:Button Padding="8,2"
                               Appearance="Secondary"
                               Content="{localization:Loc Action_CenterFocus, Fallback=Center}"
                               IsEnabled="{Binding CanAdjustFocus}"
                               AutomationProperties.Name="{localization:Loc Action_CenterFocus, Fallback='Center crop focus'}"
                               Click="CenterFocus_Click" />
                  </StackPanel>
                </Grid>
                <TextBlock Style="{StaticResource CaptionTextStyle}"
                           Text="{localization:Loc Hint_FocusControl, Fallback='Drag the marker or use the arrow keys. Hold Shift for larger steps.'}" />
              </StackPanel>

              <Grid>
                <TextBlock Style="{StaticResource InspectorLabelStyle}"
                           Text="{localization:Loc Label_PanelOpacity, Fallback='Panel opacity'}" />
                <TextBlock HorizontalAlignment="Right"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                           Text="{Binding PanelOpacityPercent}" />
              </Grid>
              <Slider Minimum="0.60"
                      Maximum="0.95"
                      TickFrequency="0.01"
                      Value="{Binding PanelOpacity, Mode=TwoWay}"
                      IsEnabled="{Binding CanEdit}"
                      AutomationProperties.Name="{localization:Loc Label_PanelOpacity, Fallback='Panel opacity'}"
                      Margin="0,0,0,16" />

              <Grid>
                <TextBlock Style="{StaticResource InspectorLabelStyle}"
                           Text="{localization:Loc Label_Blur, Fallback='Background blur'}" />
                <TextBlock HorizontalAlignment="Right"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                           Text="{Binding BlurLabel}" />
              </Grid>
              <Slider Minimum="0"
                      Maximum="24"
                      TickFrequency="1"
                      IsSnapToTickEnabled="True"
                      Value="{Binding BlurPx, Mode=TwoWay}"
                      IsEnabled="{Binding CanEdit}"
                      AutomationProperties.Name="{localization:Loc Label_Blur, Fallback='Background blur'}" />

              <Grid Margin="0,16,0,0">
                <TextBlock Style="{StaticResource InspectorLabelStyle}"
                           Text="{localization:Loc Label_DarkOverlay, Fallback='Dark theme overlay'}" />
                <TextBlock HorizontalAlignment="Right"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                           Text="{Binding DarkOverlayPercent}" />
              </Grid>
              <Slider Minimum="0"
                      Maximum="0.60"
                      TickFrequency="0.01"
                      Value="{Binding DarkOverlay, Mode=TwoWay}"
                      IsEnabled="{Binding CanEdit}"
                      AutomationProperties.Name="{localization:Loc Label_DarkOverlay, Fallback='Dark theme overlay'}"
                      Margin="0,0,0,16" />

              <Grid>
                <TextBlock Style="{StaticResource InspectorLabelStyle}"
                           Text="{localization:Loc Label_LightOverlay, Fallback='Light theme overlay'}" />
                <TextBlock HorizontalAlignment="Right"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                           Text="{Binding LightOverlayPercent}" />
              </Grid>
              <Slider Minimum="0"
                      Maximum="0.60"
                      TickFrequency="0.01"
                      Value="{Binding LightOverlay, Mode=TwoWay}"
                      IsEnabled="{Binding CanEdit}"
                      AutomationProperties.Name="{localization:Loc Label_LightOverlay, Fallback='Light theme overlay'}" />
            </StackPanel>
          </ui:Card>

          <ui:Card>
            <Grid Margin="16">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
              </Grid.ColumnDefinitions>
              <Border Width="34" Height="34" CornerRadius="10"
                      Background="{DynamicResource AccentFillColorSecondaryBrush}">
                <ui:SymbolIcon Symbol="ShieldLock24"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center" />
              </Border>
              <StackPanel Grid.Column="1" Margin="11,0,10,0">
                <TextBlock Style="{StaticResource SectionHeadingStyle}"
                           Text="{localization:Loc Section_SafetyPrivacy, Fallback='Safety &amp; privacy'}" />
                <TextBlock Margin="0,3,0,0"
                           Style="{StaticResource CaptionTextStyle}"
                           Text="{localization:Loc Risk_Summary, Fallback='Enhanced launch uses a local Chromium debugging endpoint.'}" />
              </StackPanel>
              <ui:Button Grid.Column="2"
                         VerticalAlignment="Center"
                         Content="{localization:Loc Action_LearnMore, Fallback='Review'}"
                         IsEnabled="{Binding CanEdit}"
                         Click="ReviewRisk_Click" />
            </Grid>
          </ui:Card>
        </StackPanel>
      </ScrollViewer>
    </Grid>

    <Border Grid.Row="2"
            Padding="24,12,24,16"
            Background="{DynamicResource ApplicationBackgroundBrush}"
            BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
            BorderThickness="0,1,0,0">
      <Grid>
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto" />
          <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ui:InfoBar Grid.Row="0"
                    Margin="0,0,0,10"
                    AutomationProperties.LiveSetting="Polite"
                    IsOpen="{Binding IsStatusOpen, Mode=TwoWay}"
                    IsClosable="True"
                    Title="{Binding StatusTitle}"
                    Message="{Binding StatusMessage}"
                    Severity="{Binding StatusTone, Converter={StaticResource StatusToneConverter}}" />

        <Grid Grid.Row="1">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
          </Grid.ColumnDefinitions>

          <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
            <ui:ProgressRing Width="22"
                             Height="22"
                             Margin="0,0,9,0"
                             IsIndeterminate="True"
                             Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}" />
            <TextBlock VerticalAlignment="Center"
                       Text="{Binding OperationStage}"
                       Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
            <ui:Button Margin="10,0,0,0"
                       Appearance="Transparent"
                       Content="{localization:Loc Action_Cancel, Fallback=Cancel}"
                       Command="{Binding CancelCommand}"
                       Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}" />
            <ui:Button Margin="10,0,0,0"
                       Appearance="Transparent"
                       Content="{localization:Loc Action_Retry, Fallback=Retry}"
                       Command="{Binding RetryShortcutCommand}"
                       Visibility="{Binding ShortcutNeedsRetry, Converter={StaticResource BooleanToVisibilityConverter}}" />
          </StackPanel>

          <WrapPanel Grid.Column="1" HorizontalAlignment="Right">
            <ui:Button Margin="0,0,8,0"
                       Content="{Binding PauseButtonText}"
                       Command="{Binding TogglePauseCommand}" />
            <ui:Button Margin="0,0,8,0"
                       Content="{localization:Loc Action_RestoreOfficial, Fallback='Restore official'}"
                       Command="{Binding DisableCommand}" />
            <ui:Button MinWidth="154"
                       Appearance="Primary"
                       Content="{Binding ApplyButtonText}"
                       IsEnabled="{Binding CanEdit}"
                       Click="Apply_Click" />
          </WrapPanel>
        </Grid>
      </Grid>
    </Border>

    <ui:SnackbarPresenter x:Name="SnackbarPresenter"
                          Grid.Row="1"
                          Grid.RowSpan="2"
                          HorizontalAlignment="Right"
                          VerticalAlignment="Bottom"
                          Margin="24,24,24,88" />
    <ui:ContentDialogHost x:Name="DialogHost"
                          Grid.Row="0"
                          Grid.RowSpan="3"
                          IsDisableSiblingsEnabled="True" />
  </Grid>
</ui:FluentWindow>
